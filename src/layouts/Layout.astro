---
interface Props {
  title: string
  description: string
}

const { title, description } = Astro.props
const pathname = Astro.url.pathname
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/jpswalsh/academicons@1/css/academicons.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
  </head>
  <body class="max-w-screen-md mx-auto">
    <div class="header">
      <header class="flex flex-col sm:flex-row items-center gap-5 sm:gap-10 pt-16 py-12">
        <div class="flex flex-col gap-5">
          <a href="/">
            <h1 id="site-title">Kuk Jin Jang</h1>
          </a>
          <nav>
            <ul>
              <li>
                <a href="/" class={pathname === "/" ? "active" : ""}>about</a>
              </li>
              <li>
                <a
                  href="/publications"
                  class={pathname === "/publications" || pathname === "/publications/"
                    ? "active"
                    : ""}
                >
                  publications
                </a>
              </li>
              <li>
                <a href="/cv" class={pathname === "/cv" || pathname === "/cv/" ? "active" : ""}>
                  CV
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </header>
      <button
        class="toggle-theme"
        aria-label="Toggle Theme"
        title="Toggle Theme"
        onclick="toggleTheme()"
      >
        <span class="theme-icon light" style="display:none">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
            ></path>
          </svg>
        </span>
        <span class="theme-icon dark" style="display:block">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
            ></path>
          </svg>
        </span>
      </button>
    </div>

    <main id="content">
      <slot />
    </main>

    <footer class="pt-5 pb-10 grid gap-3 sm:grid-cols-2">
      <div class="text-xs font-semibold text-gray-500 order-2 sm:order-1">
        &copy; 2024 &mdash; Kuk Jin Jang
      </div>
    </footer>

    <script is:inline>
      ;(function () {
        const saved = localStorage.getItem("theme")
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
        const theme = saved || (prefersDark ? "dark" : "light")
        setTheme(theme)
      })()

      function setTheme(theme) {
        const html = document.documentElement
        const lightIcon = document.querySelector(".theme-icon.light")
        const darkIcon = document.querySelector(".theme-icon.dark")
        localStorage.setItem("theme", theme)
        if (theme === "light") {
          html.classList.remove("dark")
          if (lightIcon) lightIcon.style.display = "none"
          if (darkIcon) darkIcon.style.display = "block"
        } else {
          html.classList.add("dark")
          if (darkIcon) darkIcon.style.display = "none"
          if (lightIcon) lightIcon.style.display = "block"
        }
      }

      function toggleTheme() {
        const current = localStorage.getItem("theme") || "light"
        setTheme(current === "light" ? "dark" : "light")
      }
    </script>

    <style is:global>
      /* Reset & Base */
      *,
      *::after,
      *::before {
        border: 0 solid #e5e7eb;
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "avenir next",
          avenir,
          "segoe ui",
          "helvetica neue",
          helvetica,
          Cantarell,
          Ubuntu,
          roboto,
          noto,
          arial,
          sans-serif;
        line-height: 1.5;
        -moz-tab-size: 4;
        tab-size: 4;
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        line-height: inherit;
        background-color: rgb(255 255 255);
        color: rgb(55 65 81);
        font-size: 1.125rem;
        line-height: 1.75rem;
        text-align: justify;
      }

      html.dark body {
        background-color: rgb(17 24 39);
        color: rgb(209 213 219);
      }

      hr {
        border-top-width: 1px;
        color: inherit;
        height: 0;
        margin: 1.5rem 0;
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        color: rgb(17 24 39);
        font-weight: 700;
        margin-bottom: 1.25rem;
        padding-top: 0.5rem;
        font-size: inherit;
        margin: 0;
      }

      html.dark h1,
      html.dark h2,
      html.dark h3,
      html.dark h4,
      html.dark h5,
      html.dark h6 {
        color: rgb(209 213 219);
      }

      a {
        color: inherit;
        text-decoration: inherit;
      }

      ul,
      ol {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      button {
        cursor: pointer;
        background-color: transparent;
        background-image: none;
        font-family: inherit;
        font-size: 100%;
        line-height: inherit;
        margin: 0;
        padding: 0;
      }

      img,
      svg {
        display: block;
        vertical-align: middle;
      }

      /* Layout Utilities */
      .max-w-screen-md {
        max-width: 768px;
      }
      .mx-auto {
        margin-left: auto;
        margin-right: auto;
      }
      .flex {
        display: flex;
      }
      .flex-col {
        flex-direction: column;
      }
      .flex-row {
        flex-direction: row;
      }
      .items-center {
        align-items: center;
      }
      .flex-none {
        flex: none;
      }
      .gap-1 {
        gap: 0.25rem;
      }
      .gap-5 {
        gap: 1.25rem;
      }
      .gap-10 {
        gap: 2.5rem;
      }
      .gap-3 {
        gap: 0.75rem;
      }
      .mt-2 {
        margin-top: 0.5rem;
      }
      .overflow-hidden {
        overflow: hidden;
      }
      .rounded-full {
        border-radius: 9999px;
      }
      .w-20 {
        width: 5rem;
      }
      .h-20 {
        height: 5rem;
      }
      .w-4 {
        width: 1rem;
      }
      .h-4 {
        height: 1rem;
      }
      .stroke-2 {
        stroke-width: 2;
      }
      .pt-16 {
        padding-top: 4rem;
      }
      .py-12 {
        padding-top: 3rem;
        padding-bottom: 3rem;
      }
      .py-2 {
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
      }
      .pb-10 {
        padding-bottom: 2.5rem;
      }
      .pt-5 {
        padding-top: 1.25rem;
      }
      .grid {
        display: grid;
      }
      .text-xs {
        font-size: 0.75rem;
        line-height: 1rem;
      }
      .font-semibold {
        font-weight: 600;
      }
      .font-normal {
        font-weight: 400;
      }
      .order-2 {
        order: 2;
      }
      .order-1 {
        order: 1;
      }
      .text-gray-500 {
        color: rgb(107 114 128);
      }

      /* Header */
      .header {
        align-items: center;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
      }

      .toggle-theme {
        height: 1.5rem;
        width: 1.5rem;
        color: rgb(107 114 128);
      }

      .toggle-theme:hover {
        color: rgb(17 24 39);
      }

      html.dark .toggle-theme {
        color: rgb(156 163 175);
      }

      html.dark .toggle-theme:hover {
        color: rgb(243 244 246);
      }

      /* Site Title */
      #site-title {
        color: rgb(31 41 55);
        font-size: 2.25rem;
        font-weight: 800;
        line-height: 2.5rem;
        text-align: center;
        margin-bottom: 0;
        padding-top: 0;
      }

      html.dark #site-title {
        color: rgb(243 244 246);
      }

      /* Navigation */
      header nav > ul {
        display: flex;
        flex-wrap: wrap;
        font-size: 0.75rem;
        font-weight: 600;
        gap: 1.75rem;
        justify-content: center;
        line-height: 1rem;
        text-transform: lowercase;
        width: fit-content;
      }

      nav a,
      footer a {
        color: rgb(107 114 128);
        font-weight: 600;
      }

      nav a:hover,
      footer a:hover {
        color: rgb(17 24 39);
      }

      html.dark nav a,
      html.dark footer a {
        color: rgb(156 163 175);
      }

      html.dark nav a:hover,
      html.dark footer a:hover {
        color: rgb(243 244 246);
      }

      nav a.active {
        color: rgb(17 24 39);
      }

      html.dark nav a.active {
        color: rgb(243 244 246);
      }

      /* Content */
      #content {
        line-height: 1.5;
      }

      #content a {
        color: rgb(4 120 87);
        font-weight: 700;
        text-decoration-line: underline;
      }

      #content a:hover {
        color: rgb(5 150 105);
      }

      html.dark #content a {
        color: rgb(110 231 183);
      }

      html.dark #content a:hover {
        color: rgb(167 243 208);
      }

      #content .date {
        color: rgb(156 163 175);
        font-size: 0.875rem;
        font-weight: 600;
        line-height: 1.25rem;
        padding-bottom: 0.5rem;
        padding-top: 0.5rem;
      }

      #content h1 > a {
        font-size: 1.25rem;
        font-weight: 700;
        line-height: 1.75rem;
        text-decoration-line: none;
        color: rgb(17 24 39);
      }

      #content h1 > a:hover {
        text-decoration-line: underline;
      }

      html.dark #content h1 > a {
        color: rgb(209 213 219);
      }

      html.dark #content h1 > a:hover {
        color: rgb(243 244 246);
      }

      #content .description {
        color: rgb(75 85 99);
        font-size: 1rem;
        line-height: 1.5rem;
      }

      html.dark #content .description {
        color: rgb(209 213 219);
      }

      #content .read-more {
        align-items: center;
        color: rgb(4 120 87);
        display: inline-flex;
        font-size: 0.875rem;
        font-weight: 600;
        gap: 0.5rem;
        line-height: 1.25rem;
        text-decoration-line: none;
      }

      #content .read-more:hover {
        color: rgb(5 150 105);
      }

      html.dark #content .read-more {
        color: rgb(110 231 183);
      }

      html.dark #content .read-more:hover {
        color: rgb(167 243 208);
      }

      /* Titles */
      .title-small {
        color: rgb(17 24 39);
        font-size: 1.5rem;
        font-weight: 800;
        line-height: 2rem;
        margin-bottom: 1rem;
        padding-top: 0;
      }

      html.dark .title-small {
        color: rgb(209 213 219);
      }

      /* Footer */
      footer {
        font-size: 0.75rem;
        line-height: 1rem;
      }

      footer ul {
        display: flex;
        gap: 1.25rem;
      }

      /* Profile image in header */
      .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      /* About section */
      .about-section {
        padding-bottom: 1rem;
      }

      .profile-block {
        display: flex;
        flex-direction: column-reverse;
        gap: 1.5rem;
      }

      .profile-text p {
        margin: 0 0 1rem 0;
      }

      .profile-text p strong {
        font-weight: 700;
        color: rgb(17 24 39);
      }

      html.dark .profile-text p strong {
        color: rgb(209 213 219);
      }

      .affiliation {
        font-size: 1rem;
        color: rgb(107 114 128);
        margin-bottom: 1rem;
      }

      .affiliation a {
        color: rgb(4 120 87);
        font-weight: 700;
        text-decoration-line: underline;
      }

      .affiliation a:hover {
        color: rgb(5 150 105);
      }

      html.dark .affiliation a {
        color: rgb(110 231 183);
      }

      html.dark .affiliation a:hover {
        color: rgb(167 243 208);
      }

      .email {
        display: block;
        margin-top: 0.25rem;
      }

      .profile-picture {
        flex: none;
        width: 100%;
        max-width: 280px;
        margin: 0 auto;
      }

      .profile-picture img {
        width: 100%;
        height: auto;
        border-radius: 0.375rem;
      }

      /* News section */
      .news-section {
        padding-bottom: 1rem;
      }

      .news-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .news-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        font-size: 1rem;
        line-height: 1.5rem;
      }

      .news-date {
        color: rgb(75 85 99);
        font-weight: 600;
        font-size: 0.875rem;
        white-space: nowrap;
        min-width: 120px;
      }

      html.dark .news-date {
        color: rgb(156 163 175);
      }

      .news-text {
        color: rgb(55 65 81);
      }

      html.dark .news-text {
        color: rgb(209 213 219);
      }

      /* Publications section */
      .publications-section {
        padding-bottom: 1rem;
      }

      .publications-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .publication {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }

      .pub-title {
        font-size: 1.125rem;
        font-weight: 700;
        line-height: 1.5rem;
        color: rgb(17 24 39);
      }

      html.dark .pub-title {
        color: rgb(209 213 219);
      }

      .pub-authors {
        font-size: 1rem;
        color: rgb(75 85 99);
      }

      html.dark .pub-authors {
        color: rgb(156 163 175);
      }

      .pub-venue {
        font-size: 1rem;
        color: rgb(107 114 128);
        font-style: italic;
      }

      html.dark .pub-venue {
        color: rgb(156 163 175);
      }

      .pub-links {
        margin-top: 0.25rem;
      }

      .pub-links a {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        font-size: 0.875rem;
        font-weight: 600;
        border: 1px solid rgb(4 120 87);
        border-radius: 0.25rem;
        text-decoration: none;
        color: rgb(4 120 87);
        margin-right: 0.5rem;
      }

      .pub-links a:hover {
        background-color: rgb(4 120 87);
        color: white;
      }

      html.dark .pub-links a {
        border-color: rgb(110 231 183);
        color: rgb(110 231 183);
      }

      html.dark .pub-links a:hover {
        background-color: rgb(110 231 183);
        color: rgb(17 24 39);
      }

      /* Social section */
      .social-section {
        padding-bottom: 2rem;
        text-align: center;
      }

      .contact-icons {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 0.75rem;
      }

      .contact-icons a {
        font-size: 1.5rem;
        color: rgb(75 85 99);
        text-decoration: none;
      }

      .contact-icons a:hover {
        color: rgb(17 24 39);
      }

      html.dark .contact-icons a {
        color: rgb(156 163 175);
      }

      html.dark .contact-icons a:hover {
        color: rgb(243 244 246);
      }

      .contact-note {
        font-size: 1rem;
        color: rgb(107 114 128);
      }

      html.dark .contact-note {
        color: rgb(156 163 175);
      }

      /* Divider */
      hr {
        border-color: rgb(229 231 235);
      }

      html.dark hr {
        border-color: rgb(55 65 81);
      }

      /* Responsive */
      @media (min-width: 640px) {
        .sm\:flex-row {
          flex-direction: row;
        }
        .sm\:gap-10 {
          gap: 2.5rem;
        }
        .sm\:grid-cols-2 {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
        .sm\:order-1 {
          order: 1;
        }
        .sm\:order-2 {
          order: 2;
        }
        .sm\:justify-end {
          justify-content: flex-end;
        }
        #site-title {
          text-align: left;
        }

        .profile-block {
          flex-direction: row;
        }

        .profile-picture {
          margin: 0;
          width: 200px;
        }

        .news-item {
          flex-direction: row;
          gap: 1rem;
        }
      }
    </style>
  </body>
</html>
